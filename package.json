    "./auth/oauth": "./src/auth/oauth.ts",
    "./db/sync-log": "./src/db/sync-log.ts",
    "./jobs/queues": "./src/jobs/queues.ts",
    "./jobs/provider-queue-config": "./src/jobs/provider-queue-config.ts",
    "./jobs/process-export-job": "./src/jobs/process-export-job.ts",
    "./personalization/params": "./src/personalization/params.ts",
    "./personalization/storage": "./src/personalization/storage.ts",
    "./personalization/refit": "./src/personalization/refit.ts",
    "./sync-metrics": "./src/sync-metrics.ts"
  },
  "scripts": {
    "dev": "./scripts/with-env.sh tsx src/index.ts",
    "sync": "./scripts/with-env.sh tsx src/index.ts sync",
    "auth": "./scripts/with-env.sh tsx src/index.ts auth",
    "migrate": "./scripts/with-env.sh drizzle-kit migrate && tsx scripts/generate-schema-diagram.ts",
    "seed": "tsx scripts/seed-dev-db.ts",
    "generate": "drizzle-kit generate && tsx scripts/generate-schema-diagram.ts",
    "schema:diagram": "tsx scripts/generate-schema-diagram.ts",
    "schema:view": "tsx scripts/generate-schema-diagram.ts --open",
    "lint": "biome check . --max-diagnostics=500 && bash scripts/no-suppressions.sh && bash scripts/exact-versions.sh && sherif",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:changed": "vitest run --changed origin/main",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "knip": "knip --config knip.json",
    "server": "./scripts/with-env.sh tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:mobile": "vitest run --project mobile",
    "test:mobile:watch": "vitest --watch --project mobile",
    "e2e:web:up": "docker compose -f docker-compose.e2e.yml up -d --build --wait",
    "e2e:web:down": "docker compose -f docker-compose.e2e.yml down -v",
    "e2e:web:run": "pnpm exec cypress run",
    "e2e:web:open": "pnpm exec cypress open",
    "e2e:web": "pnpm e2e:web:up && pnpm e2e:web:run; pnpm e2e:web:down",
    "mobile": "pnpm --filter dofek-mobile start",
    "mobile:device": "pnpm --filter dofek-mobile ios:device",
    "storybook": "pnpm --filter dofek-web storybook",
    "storybook:build": "pnpm --filter dofek-web build-storybook",
    "storybook:web": "pnpm --filter dofek-web storybook",
    "storybook:web:build": "pnpm --filter dofek-web build-storybook",
    "storybook:mobile": "pnpm --filter dofek-mobile storybook",
    "storybook:mobile:ios": "pnpm --filter dofek-mobile storybook:ios",
    "size": "size-limit",
    "depcruise": "depcruise --config .dependency-cruiser.cjs src/ packages/",
    "spellcheck": "cspell --no-progress",
    "check:mobile-update": "./scripts/check-mobile-update.sh"
  },
  "dependencies": {
    "@bull-board/api": "6.20.5",
    "@bull-board/express": "6.20.5",
