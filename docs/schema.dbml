table fitness.sync_log {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  data_type text [not null]
  status text [not null]
  record_count integer [default: 0]
  error_message text
  duration_ms integer
  synced_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (provider_id, data_type, synced_at) [name: 'sync_log_provider_type_idx']
    synced_at [name: 'sync_log_synced_at_idx']
  }
}

table fitness.training_export_watermark {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  table_name text [not null, unique]
  last_exported_at "timestamp with time zone" [not null]
  row_count bigint [not null, default: 0]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}

table fitness.user_billing {
  user_id uuid [pk, not null]
  stripe_customer_id text [unique]
  stripe_subscription_id text [unique]
  stripe_subscription_status text
  stripe_current_period_end "timestamp with time zone"
  paid_grant_reason text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    stripe_customer_id [name: 'user_billing_stripe_customer_idx']
    stripe_subscription_id [name: 'user_billing_stripe_subscription_idx']
  }
}

table fitness.user_profile {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  name text [not null]
  email text [unique]
  birth_date date
  max_hr smallint
  resting_hr smallint
  ftp smallint
  is_admin boolean [not null, default: false]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}

table fitness.user_settings {
  user_id uuid [not null]
  key text [not null]
  value jsonb [not null]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, key) [pk]
  }
}

table fitness.webhook_subscription {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text
  provider_name text [not null]
  subscription_external_id text
  verify_token text [not null]
  signing_secret text
  status text [not null, default: 'active']
  expires_at "timestamp with time zone"
  metadata jsonb
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    provider_id [name: 'webhook_subscription_provider_id_idx', unique]
    provider_name [name: 'webhook_subscription_provider_name_idx']
  }
}

