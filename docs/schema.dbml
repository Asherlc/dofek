  snacks
  soups
  sweets_candy_and_desserts
  vegetables
  supplement
  other
}

enum lab_result_status {
  final
  preliminary
  corrected
  cancelled
}

enum meal {
  breakfast
  lunch
  dinner
  snack
  other
}

enum set_type {
  working
  warmup
  dropset
  failure
}

enum sleep_stage_name {
  deep
  light
  rem
  awake
}

table fitness.activity {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  activity_type activity_type [not null]
  started_at "timestamp with time zone" [not null]
  ended_at "timestamp with time zone"
  name text
  notes text
  perceived_exertion real
  source_name text
  timezone text
  strava_id text
  raw jsonb
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'activity_provider_external_idx', unique]
    (user_id, provider_id) [name: 'activity_user_provider_idx']
  }
}

table fitness.activity_interval {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  activity_id uuid [not null]
  interval_index integer [not null]
  label text
  interval_type text
  started_at "timestamp with time zone" [not null]
  ended_at "timestamp with time zone"
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (activity_id, interval_index) [name: 'activity_interval_activity_idx']
  }
}

table fitness.allergy_intolerance {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  name text [not null]
  type text
  clinical_status text
  verification_status text
  rxnorm_code text
  onset_date date
  reactions jsonb
  source_name text
  raw jsonb
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'allergy_intolerance_provider_external_idx', unique]
    (user_id, provider_id) [name: 'allergy_intolerance_user_provider_idx']
  }
}

table fitness.auth_account {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  auth_provider text [not null]
  provider_account_id text [not null]
  email text
  name text
  groups text[]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (auth_provider, provider_account_id) [name: 'auth_account_provider_id_idx', unique]
    user_id [name: 'auth_account_user_idx']
  }
}

table fitness.body_measurement {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  recorded_at "timestamp with time zone" [not null]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  weight_kg real
  body_fat_pct real
  muscle_mass_kg real
  bone_mass_kg real
  water_pct real
  bmi real
  height_cm real
  waist_circumference_cm real
  systolic_bp integer
  diastolic_bp integer
  heart_pulse integer
  temperature_c real
  source_name text
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'body_measurement_provider_external_idx', unique]
    (user_id, provider_id) [name: 'body_measurement_user_provider_idx']
  }
}

table fitness.body_measurement_value {
  body_measurement_id uuid [not null]
  measurement_type_id text [not null]
  value real [not null]

  indexes {
    (body_measurement_id, measurement_type_id) [pk]
    body_measurement_id [name: 'body_measurement_value_entry_idx']
    measurement_type_id [name: 'body_measurement_value_type_idx']
  }
}

table fitness.breathwork_session {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  technique_id text [not null]
  rounds integer [not null]
  duration_seconds integer [not null]
  started_at "timestamp with time zone" [not null]
  notes text
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    user_id [name: 'breathwork_session_user_idx']
    started_at [name: 'breathwork_session_started_at_idx']
  }
}

table fitness.condition {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  name text [not null]
  clinical_status text
  verification_status text
  icd10_code text
  snomed_code text
  onset_date date
  abatement_date date
  recorded_date date
  source_name text
  raw jsonb
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'condition_provider_external_idx', unique]
    (user_id, provider_id) [name: 'condition_user_provider_idx']
  }
}

table fitness.daily_metric_type {
  id text [pk, not null]
  display_name text [not null]
  unit text
  category text [not null]
  priority_category text [not null, default: 'activity']
  sort_order integer [not null, default: 0]
  is_integer boolean [not null, default: false]
}

table fitness.daily_metric_value {
  daily_metrics_id uuid [not null]
  metric_type_id text [not null]
  value real [not null]

  indexes {
    (daily_metrics_id, metric_type_id) [pk]
    daily_metrics_id [name: 'daily_metric_value_entry_idx']
    metric_type_id [name: 'daily_metric_value_type_idx']
  }
}

table fitness.daily_metrics {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  date date [not null]
  provider_id text [not null]
  user_id uuid [not null]
  resting_hr integer
  hrv real
  vo2max real
  spo2_avg real
  respiratory_rate_avg real
  steps integer
  active_energy_kcal real
  basal_energy_kcal real
  distance_km real
  cycling_distance_km real
  flights_climbed integer
  exercise_minutes integer
  walking_speed real
  walking_step_length real
  walking_double_support_pct real
  walking_asymmetry_pct real
  walking_steadiness real
  stand_hours integer
  skin_temp_c real
  stress_high_minutes integer
  recovery_high_minutes integer
  resilience_level text
  push_count integer
  wheelchair_distance_km real
  uv_exposure real
  source_name text
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id) [name: 'daily_metrics_user_provider_idx']
  }
}

table fitness.dexa_scan {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text [not null]
  recorded_at "timestamp with time zone" [not null]
  scanner_model text
  total_fat_mass_kg real
  total_lean_mass_kg real
  total_bone_mass_kg real
  total_mass_kg real
  body_fat_pct real
  android_gynoid_ratio real
  visceral_fat_mass_kg real
  visceral_fat_volume_cm3 real
  total_bone_mineral_density real
  bone_density_t_percentile real
  bone_density_z_percentile real
  resting_metabolic_rate_kcal real
  resting_metabolic_rate_raw jsonb
  percentiles jsonb
  height_inches real
  weight_pounds real
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'dexa_scan_provider_external_idx', unique]
    (user_id, provider_id) [name: 'dexa_scan_user_provider_idx']
    recorded_at [name: 'dexa_scan_recorded_at_idx']
  }
}

table fitness.dexa_scan_region {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  scan_id uuid [not null]
  region text [not null]
  fat_mass_kg real
  lean_mass_kg real
  bone_mass_kg real
  total_mass_kg real
  tissue_fat_pct real
  region_fat_pct real
  bone_mineral_density real
  bone_area_cm2 real
  bone_mineral_content_g real
  z_score_percentile real
  t_score_percentile real

  indexes {
    (scan_id, region) [name: 'dexa_scan_region_scan_region_idx', unique]
    scan_id [name: 'dexa_scan_region_scan_idx']
  }
}

table fitness.exercise {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  name text [not null]
  muscle_group text
  muscle_groups text[]
  equipment text
  exercise_type text
  movement text
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (name, equipment) [name: 'exercise_name_equipment_idx', unique]
  }
}

table fitness.exercise_alias {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  exercise_id uuid [not null]
  provider_id text [not null]
  provider_exercise_id text
  provider_exercise_name text [not null]

  indexes {
    (provider_id, provider_exercise_name) [name: 'exercise_alias_provider_name_idx', unique]
  }
}

table fitness.food_entry {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  date date [not null]
  meal meal
  food_name text [not null]
  food_description text
  category food_category
  provider_food_id text
  provider_serving_id text
  number_of_units real
  logged_at "timestamp with time zone"
  barcode text
  serving_unit text
  serving_weight_grams real
  raw jsonb
  confirmed boolean [not null, default: true]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'food_entry_provider_external_idx', unique]
    date [name: 'food_entry_date_idx']
    (date, meal) [name: 'food_entry_date_meal_idx']
    (user_id, provider_id) [name: 'food_entry_user_provider_idx']
  }
}

table fitness.food_entry_nutrient {
  food_entry_id uuid [not null]
  nutrient_id text [not null]
  amount real [not null]

  indexes {
    (food_entry_id, nutrient_id) [pk]
    food_entry_id [name: 'food_entry_nutrient_entry_idx']
  }
}

table fitness.food_entry_nutrition {
  id uuid [pk, not null, default: `gen_random_uuid()`]
