    food_entry_id [name: 'food_entry_nutrition_entry_idx']
  }
}

table fitness.health_event {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  type text [not null]
  value real
  value_text text
  unit text
  source_name text
  start_date "timestamp with time zone" [not null]
  end_date "timestamp with time zone"
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'health_event_provider_external_idx', unique]
    (type, start_date) [name: 'health_event_type_time_idx']
    (user_id, provider_id) [name: 'health_event_user_provider_idx']
  }
}

table fitness.inertial_measurement_unit_sample {
  recorded_at "timestamp with time zone" [not null]
  user_id uuid [not null]
  device_id text [not null]
  device_type text [not null]
  provider_id text [not null]
  x real [not null]
  y real [not null]
  z real [not null]
  gyroscope_x real
  gyroscope_y real
  gyroscope_z real

  indexes {
    (user_id, recorded_at) [name: 'inertial_measurement_unit_user_time_idx']
  }
}

table fitness.journal_entry {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  date date [not null]
  provider_id text [not null]
  user_id uuid [not null]
  question_slug text [not null]
  answer_text text
  answer_numeric real
  impact_score real
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, date, question_slug, provider_id) [name: 'journal_entry_user_date_question_provider_idx', unique]
    date [name: 'journal_entry_date_idx']
    (user_id, provider_id) [name: 'journal_entry_user_provider_idx']
    question_slug [name: 'journal_entry_question_slug_idx']
  }
}

table fitness.journal_question {
  slug text [pk, not null]
  display_name text [not null]
  category text [not null]
  data_type text [not null]
  unit text
  sort_order integer [not null, default: 0]
  created_at "timestamp with time zone" [not null, default: `now()`]
}

table fitness.lab_panel {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  name text [not null]
  loinc_code text
  status lab_result_status
  source_name text
  recorded_at "timestamp with time zone" [not null]
  issued_at "timestamp with time zone"
  raw jsonb
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'lab_panel_provider_external_idx', unique]
    recorded_at [name: 'lab_panel_recorded_idx']
    (user_id, provider_id) [name: 'lab_panel_user_provider_idx']
  }
}

table fitness.lab_result {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  panel_id uuid
  external_id text
  test_name text [not null]
  loinc_code text
  value real
  value_text text
  unit text
  reference_range_low real
  reference_range_high real
  reference_range_text text
  status lab_result_status
  source_name text
  recorded_at "timestamp with time zone" [not null]
  issued_at "timestamp with time zone"
  raw jsonb
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'lab_result_provider_external_idx', unique]
    recorded_at [name: 'lab_result_recorded_idx']
    loinc_code [name: 'lab_result_loinc_idx']
    test_name [name: 'lab_result_test_name_idx']
    panel_id [name: 'lab_result_panel_idx']
    (user_id, provider_id) [name: 'lab_result_user_provider_idx']
  }
}

table fitness.life_events {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  label text [not null]
  user_id uuid [not null]
  started_at date [not null]
  ended_at date
  category text
  ongoing boolean [not null, default: false]
  notes text
