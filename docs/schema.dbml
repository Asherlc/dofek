  vitamin_b2_mg real
  vitamin_b3_mg real
  vitamin_b5_mg real
  vitamin_b6_mg real
  vitamin_b7_mcg real
  vitamin_b9_mcg real
  vitamin_b12_mcg real
  calcium_mg real
  iron_mg real
  magnesium_mg real
  zinc_mg real
  selenium_mcg real
  copper_mg real
  manganese_mg real
  chromium_mcg real
