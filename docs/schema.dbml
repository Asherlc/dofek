table fitness.oauth_token {
  user_id uuid [not null]
  provider_id text [not null]
  access_token text [not null]
  refresh_token text
  expires_at "timestamp with time zone" [not null]
  scopes text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id) [pk]
    provider_id [name: 'oauth_token_provider_idx']
    user_id [name: 'oauth_token_user_idx']
  }
}

table fitness.orientation_sample {
  recorded_at "timestamp with time zone" [not null]
  user_id uuid [not null]
  provider_id text [not null]
  device_id text [not null]
  quaternion_w real [not null]
  quaternion_x real [not null]
  quaternion_y real [not null]
  quaternion_z real [not null]

  indexes {
    (user_id, recorded_at) [name: 'orientation_sample_user_time_idx']
  }
}

table fitness.provider {
  id text [pk, not null]
  name text [not null]
  api_base_url text
  user_id uuid [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, name) [name: 'provider_user_name_idx', unique]
  }
}

table fitness.session {
  id text [pk, not null]
  user_id uuid [not null]
  expires_at "timestamp with time zone" [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    user_id [name: 'session_user_idx']
    expires_at [name: 'session_expires_idx']
  }
}

table fitness.shared_report {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  share_token text [not null, unique]
  report_type text [not null]
  report_data jsonb [not null]
  expires_at "timestamp with time zone"
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    user_id [name: 'shared_report_user_idx']
  }
}

table fitness.slack_installation {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  team_id text [not null, unique]
  team_name text
  bot_token text [not null]
  bot_id text
  bot_user_id text
  app_id text
  installer_slack_user_id text
  raw_installation jsonb [not null]
  installed_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    team_id [name: 'slack_installation_team_idx']
  }
}

table fitness.sleep_session {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  started_at "timestamp with time zone" [not null]
  ended_at "timestamp with time zone"
  duration_minutes integer
  deep_minutes integer
  rem_minutes integer
  light_minutes integer
  awake_minutes integer
  efficiency_pct real
  sleep_type text
  sleep_need_baseline_minutes integer
  sleep_need_from_debt_minutes integer
  sleep_need_from_strain_minutes integer
  sleep_need_from_nap_minutes integer
  source_name text
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'sleep_session_provider_external_idx', unique]
    (user_id, provider_id) [name: 'sleep_session_user_provider_idx']
  }
}

table fitness.sleep_stage {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  session_id uuid [not null]
  stage sleep_stage_name [not null]
  started_at "timestamp with time zone" [not null]
  ended_at "timestamp with time zone" [not null]
  source_name text
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (session_id, started_at) [name: 'sleep_stage_session_idx']
  }
}

table fitness.sport_settings {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  sport text [not null]
  ftp smallint
  threshold_hr smallint
  threshold_pace_per_km real
  power_zone_pcts jsonb
  hr_zone_pcts jsonb
  pace_zone_pcts jsonb
  effective_from date [not null, default: `now()`]
  notes text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, sport, effective_from) [name: 'sport_settings_user_sport_date_idx', unique]
    user_id [name: 'sport_settings_user_idx']
  }
}

table fitness.strength_set {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  workout_id uuid [not null]
  exercise_id uuid [not null]
  exercise_index integer [not null]
  set_index integer [not null]
  set_type set_type [default: 'working']
  weight_kg real
  reps integer
  distance_meters real
  duration_seconds integer
  strap_location text
  strap_location_laterality text
  rpe real
  notes text
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    workout_id [name: 'strength_set_workout_idx']
  }
}

table fitness.strength_workout {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  provider_id text [not null]
  user_id uuid [not null]
  external_id text
  started_at "timestamp with time zone" [not null]
  ended_at "timestamp with time zone"
  name text
  notes text
  raw_msk_strain_score real
  scaled_msk_strain_score real
  cardio_strain_score real
  cardio_strain_contribution_percent real
  msk_strain_contribution_percent real
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, provider_id, external_id) [name: 'strength_workout_provider_external_idx', unique]
  }
}

table fitness.supplement {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  name text [not null]
  amount real
  unit text
  form text
  description text
  meal meal
  sort_order integer [not null, default: 0]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, name) [name: 'supplement_user_name_idx', unique]
    user_id [name: 'supplement_user_idx']
  }
}

table fitness.supplement_nutrient {
  supplement_id uuid [not null]
  nutrient_id text [not null]
  amount real [not null]

  indexes {
    (supplement_id, nutrient_id) [pk]
    supplement_id [name: 'supplement_nutrient_supplement_idx']
  }
}

table fitness.supplement_nutrition {
