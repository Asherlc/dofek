{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "plugins": [
    "./plugins/no-double-cast.grit",
    "./plugins/no-as-type-assertion.grit",
    "./plugins/no-single-letter-variables.grit",
    "./plugins/no-private-keyword.grit",
    "./plugins/no-underscore-private.grit",
    "./plugins/no-silent-catch.grit",
    "./plugins/no-hardcoded-colors.grit"
  ],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/**",
      "packages/*/src/**",
      "packages/mobile/**",
      "scripts/**",
      "cypress/**",
      "*.ts"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noTsIgnore": "error",
        "noConsole": "error"
      },
      "style": {
        "noNonNullAssertion": "error"
      },
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 1000
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/routeTree.gen.ts"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false },
      "assist": { "enabled": false }
    },
    {
      "includes": [
        "scripts/**",
        "packages/mobile/lib/telemetry.ts",
        "packages/mobile/test-setup.ts",
        "packages/server/src/lib/start-worker.ts",
        "src/instrumentation.ts",
        "src/logger.ts",
        "src/providers/whoop-api-contract.test.ts",
        "src/providers/provider-api-contracts.test.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx", "**/*.integration.test.ts"],
      "linter": {
        "rules": {
          "nursery": {
            "noExcessiveLinesPerFile": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/db/schema.ts",
        "src/providers/oura/provider.ts",
        "packages/server/src/routers/health-kit-sync.ts",
        "packages/web/src/components/DataSourcesPanel.tsx",
        "packages/mobile/app/food/add.tsx",
        "packages/mobile/app/providers/index.tsx"
      ],
      "linter": {
        "rules": {
          "nursery": {
            "noExcessiveLinesPerFile": "off"
          }
        }
      }
    }
  ],
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all"
    }
  }
}
