DATABASE_URL=postgres://health:health@localhost:5435/health

# Upload server
# UPLOAD_PORT=9877
# UPLOAD_API_KEY=your-secret-key-here

# Apple Health import directory (for auto-sync via APPLE_HEALTH_IMPORT_DIR)
# APPLE_HEALTH_IMPORT_DIR=/path/to/health-exports

# OAuth callback — set to your public URL for homelab, or leave default for local dev
# OAUTH_REDIRECT_URI=https://health.yourdomain.com/callback

# Provider API keys (enable providers by adding their keys)
# WAHOO_CLIENT_ID=
# WAHOO_CLIENT_SECRET=
# WHOOP_USERNAME=
# WHOOP_PASSWORD=
# PELOTON_USERNAME=
# PELOTON_PASSWORD=
# HEVY_API_KEY=
# INTERVALS_ICU_API_KEY=
# INTERVALS_ICU_ATHLETE_ID=

# AI nutrition analysis (at least one required for AI food input)
# Providers are tried in order: Gemini → Groq → Mistral
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
