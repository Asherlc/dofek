DATABASE_URL=postgres://health:health@localhost:5435/health

# Upload server
# UPLOAD_PORT=9877
# UPLOAD_API_KEY=your-secret-key-here

# Apple Health import directory (for auto-sync via APPLE_HEALTH_IMPORT_DIR)
# APPLE_HEALTH_IMPORT_DIR=/path/to/health-exports

# OAuth callback — set to your public URL for homelab, or leave default for local dev
# Uses _unencrypted suffix so SOPS stores it in plaintext (not a secret)
# OAUTH_REDIRECT_URI_unencrypted=https://health.yourdomain.com/callback

# Provider API keys (enable providers by adding their keys)
# WAHOO_CLIENT_ID=
# WAHOO_CLIENT_SECRET=
# RWGPS_CLIENT_ID=
# RWGPS_CLIENT_SECRET=
# WHOOP_USERNAME=
# WHOOP_PASSWORD=
# PELOTON_USERNAME=
# PELOTON_PASSWORD=
# INTERVALS_ICU_API_KEY=
# INTERVALS_ICU_ATHLETE_ID=

# Sentry error tracking DSN (server + worker)
# Uses _unencrypted suffix so SOPS stores it in plaintext
# SENTRY_DSN_unencrypted=https://<KEY>@o<ORG_ID>.ingest.us.sentry.io/<PROJECT_ID>

# AI nutrition analysis (at least one required for AI food input)
# Providers are tried in order: Gemini → Mistral
# GEMINI_API_KEY=
# MISTRAL_API_KEY=

# Cloudflare R2 object storage (training data files)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
