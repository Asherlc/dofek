# Non-secret configuration — committed to the repo.
# Copy to .env.local for local overrides (gitignored).
# Actual secrets (API keys, client secrets, tokens) live in Infisical.

DATABASE_URL=postgres://health:health@localhost:5435/health

# OAuth callback — set to your public URL
# OAUTH_REDIRECT_URI=https://health.yourdomain.com/callback

# OAuth client IDs (register with each provider, then add here)
# WAHOO_CLIENT_ID=
# POLAR_CLIENT_ID=
# STRAVA_CLIENT_ID=
# OURA_CLIENT_ID=

# OpenTelemetry endpoint (AXIOM_API_TOKEN goes in Infisical; auth headers
# are constructed from it in with-env.sh / otel-collector-config.yaml)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.axiom.co

# Optional: switch Node error reporting backend to Bugsnag
# ERROR_REPORTER=bugsnag
# BUGSNAG_API_KEY=

# Cloudflare R2 endpoint (access keys go in Infisical)
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
