{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true,
    "jsx": "react-jsx",
    "outDir": "dist/server",
    "noEmit": false
  },
  "include": ["src/server", "src/shared"]
}
