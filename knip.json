{
  "workspaces": {
    ".": {
      "entry": [
        "src/index.ts",
        "src/server.ts",
        "src/jobs/worker.ts",
        "vitest.config.mutation.ts"
      ],
      "project": ["src/**/*.ts", "*.config.{ts,js,json}"],
      "ignoreDependencies": ["sharp", "tsx"],
      "ignoreBinaries": [
        "tsr", "expo", "license-checker", "squawk", "diff-cover", "pip",
        "GPL-2.0-or-later", "GPL-3.0-only", "GPL-3.0-or-later",
        "AGPL-1.0-only", "AGPL-3.0-only", "AGPL-3.0-or-later"
      ],
      "vitest": {
        "config": ["vitest.config.ts"],
        "entry": ["src/**/*.test.ts", "src/**/*.integration.test.ts"]
      }
    },
    "packages/server": {
      "vitest": {
        "config": ["../../vitest.config.ts"],
        "entry": ["src/**/*.test.ts", "src/**/*.integration.test.ts"]
      }
    },
    "packages/web": {
      "ignoreDependencies": ["@tanstack/router-cli"],
      "vitest": {
        "config": ["../../vitest.config.ts"],
        "entry": ["src/**/*.test.{ts,tsx}"]
      }
    },
    "packages/mobile": {
      "ignore": ["**/*"],
      "ignoreDependencies": ["react-native-reanimated", "expo-haptics"]
    },
    "packages/whoop-whoop": {
      "vitest": {
        "config": ["../../vitest.config.ts"],
        "entry": ["src/**/*.test.ts"]
      }
    },
    "packages/eight-sleep": {},
    "packages/zwift-client": {
      "vitest": {
        "config": ["../../vitest.config.ts"],
        "entry": ["src/**/*.test.ts"]
      }
    },
    "packages/trainerroad-client": {},
    "packages/velohero-client": {
      "vitest": {
        "config": ["../../vitest.config.ts"],
        "entry": ["src/**/*.test.ts"]
      }
    },
    "packages/garmin-connect": {
      "vitest": {
        "config": ["../../vitest.config.ts"],
        "entry": ["src/**/*.test.ts"]
      }
    },
    "packages/trainingpeaks-connect": {
      "vitest": {
        "config": ["../../vitest.config.ts"],
        "entry": ["src/**/*.test.ts"]
      }
    }
  },
  "ignoreExportsUsedInFile": true
}
