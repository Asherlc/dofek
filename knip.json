{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreWorkspaces": ["packages/ios"],
  "ignoreBinaries": ["tsr"],
  "ignoreDependencies": ["tsx", "wait-on"],
  "workspaces": {
    ".": {
      "entry": ["src/index.ts", "src/server.ts", "scripts/*.{ts,mjs}"],
      "project": ["src/**/*.ts"]
    },
    "packages/server": {
      "entry": ["src/index.ts"]
    },
    "packages/web": {
      "entry": ["src/**/*.test.{ts,tsx}"],
      "ignoreDependencies": ["@tanstack/router-cli"]
    }
  }
}
