{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "vitest": {
    "configFile": "vitest.config.mutation.ts"
  },
  "ignoreStatic": true,
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "mutate": [
    "src/providers/index.ts",
    "src/providers/strong-csv.ts",
    "src/providers/cronometer-csv.ts",
    "src/fit/*.ts",
    "src/auth/*.ts",
    "packages/web/src/lib/units.ts",
    "packages/web/src/lib/poll-sync-job.ts",
    "packages/server/src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/test-helpers.ts",
    "!packages/server/src/**/*.test.ts"
  ],
  "ignorePatterns": [
    "packages/ios/**",
    "packages/whoop-whoop/**",
    "dist/**",
    "drizzle/**"
  ],
  "testRunnerNodeArgs": ["--import", "tsx"],
  "timeoutMS": 30000,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  },
  "reporters": ["clear-text", "html", "progress"],
  "concurrency": 4
}
