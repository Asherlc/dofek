{
  "expo": {
    "name": "Dofek",
    "slug": "dofek",
    "scheme": "dofek",
    "version": "1.0.0",
    "runtimeVersion": "1.0",
    "updates": {
      "url": "https://ota.dofek.asherlc.com/manifest",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000,
      "codeSigningCertificate": "./certs/certificate.pem",
      "codeSigningMetadata": {
        "keyid": "main",
        "alg": "rsa-v1_5-sha256"
      },
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dofek.app",
      "usesAppleSignIn": true,
      "deploymentTarget": "16.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "Dofek reads your health data to sync workouts, heart rate, sleep, and body metrics to your personal dashboard.",
        "NSHealthUpdateUsageDescription": "Dofek writes dietary data back to Apple Health so your nutrition is tracked alongside activity data.",
        "NSHealthClinicalHealthRecordsShareUsageDescription": "Dofek reads your clinical health records (like lab results) to provide a complete picture of your health.",
        "NSMotionUsageDescription": "Dofek records accelerometer data to analyze movement patterns, detect activities, and provide fitness insights.",
        "NSBluetoothAlwaysUsageDescription": "Dofek connects to your WHOOP strap via Bluetooth to record accelerometer data during workouts.",
        "UIBackgroundModes": ["bluetooth-central", "fetch", "location"],
        "BGTaskSchedulerPermittedIdentifiers": ["com.dofek.accelerometer-refresh"],
        "LSSupportsOpeningDocumentsInPlace": false,
        "CADisableMinimumFrameDurationOnPhone": true,
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Dofek Import File",
            "CFBundleTypeRole": "Viewer",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "public.comma-separated-values-text",
              "public.zip-archive",
              "public.xml"
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true,
        "com.apple.developer.healthkit.access": ["health-records"]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Dofek uses the camera to scan food barcodes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Dofek records your GPS track during workouts to show your route and distance.",
          "locationAlwaysAndWhenInUsePermission": "Dofek records your GPS track during workouts to show your route and distance, even when the app is in the background.",
          "isIosBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0",
            "extraPods": [
              {
                "name": "ExpoHealthKit",
                "path": "../modules/health-kit/ios"
              },
              {
                "name": "ExpoCoreMotion",
                "path": "../modules/core-motion/ios"
              },
              {
                "name": "ExpoWatchMotion",
                "path": "../modules/watch-motion/ios"
              },
              {
                "name": "ExpoWhoopBle",
                "path": "../modules/whoop-ble/ios"
              }
            ]
          }
        }
      ],
      "@bacons/apple-targets",
      "./plugins/with-podfile-post-install"
    ]
  }
}
